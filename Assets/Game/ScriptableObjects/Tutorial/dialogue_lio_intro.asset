  dialogueId: dialogue_lio_intro
  displayName: Lio
  isRepeatable: 1
  lines:
  - speakerName: Lio
    speakerSide: 0
    portrait: {fileID: 0}
    text: Voce acordou bem na hora errada. A nevoa desceu do bosque antes do amanhecer.
  - speakerName: Lio
    speakerSide: 0
    portrait: {fileID: 0}
    text: Mira, nossa guardia, esta perto dos campos. Fale com ela antes que os animais
      avancem.
